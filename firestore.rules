rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == "aalikirmizigul89@gmail.com" ||
        (
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
        )
      );
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isEmployeeOwner(data) {
      return isAuthenticated() && (
        (data.authUid != null && data.authUid == request.auth.uid) ||
        (data.employeeId != null && data.employeeId == request.auth.uid) ||
        (
          data.employeeId != null &&
          exists(/databases/$(database)/documents/employees/$(data.employeeId)) &&
          get(/databases/$(database)/documents/employees/$(data.employeeId)).data.authUid == request.auth.uid
        )
      );
    }

    function isValidString(val, maxLen) {
      return val is string && val.size() <= maxLen;
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAdmin() || (isOwner(userId) && request.resource.data.role == 'employee');
      allow update: if isAdmin() || (isOwner(userId) && request.resource.data.role == resource.data.role);
      allow delete: if isAdmin();
    }

    match /employees/{employeeId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.authUid == request.auth.uid);
      allow create: if isAdmin();
      allow update: if isAdmin() || (
        isAuthenticated() &&
        resource.data.authUid == request.auth.uid &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'avatar',
          'updatedAt',
          'tempPassword',
          'fcmToken',
          'notificationsEnabled'
        ]) &&
        (!('fcmToken' in request.resource.data) || isValidString(request.resource.data.fcmToken, 300))
      );
      allow delete: if isAdmin();
    }

    match /attendance_records/{recordId} {
      allow read: if isAdmin() || isEmployeeOwner(resource.data);
      allow create: if isAuthenticated();
      allow update: if isAdmin() || isEmployeeOwner(resource.data);
      allow delete: if isAdmin();
    }

    match /branches/{branchId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /shifts/{shiftId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /employee_shift_assignments/{assignmentId} {
      allow read: if isAdmin() || isEmployeeOwner(resource.data);
      allow write: if isAdmin();
    }

    match /shift_overrides/{overrideId} {
      allow read: if isAdmin() || isEmployeeOwner(resource.data);
      allow write: if isAdmin();
    }

    match /work_schedules/{scheduleId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /holidays/{holidayId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /announcements/{announcementId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /leave_requests/{requestId} {
      allow read: if isAdmin() || isEmployeeOwner(resource.data);
      allow create: if isAuthenticated();
      allow update: if isAdmin() || isEmployeeOwner(resource.data);
      allow delete: if isAdmin();
    }

    match /leave_records/{recordId} {
      allow read: if isAdmin() || isEmployeeOwner(resource.data);
      allow write: if isAdmin();
    }

    match /break_records/{recordId} {
      allow read: if isAdmin() || isEmployeeOwner(resource.data);
      allow create: if isAuthenticated();
      allow update: if isAdmin() || isEmployeeOwner(resource.data);
      allow delete: if isAdmin();
    }

    match /leave_balances/{balanceId} {
      allow read: if isAdmin() || isEmployeeOwner(resource.data);
      allow write: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /email_logs/{logId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /salary_configs/{configId} {
      allow read, write: if isAdmin();
    }

    match /salary_records/{recordId} {
      allow read: if isAdmin() || isEmployeeOwner(resource.data);
      allow write: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() &&
        resource.data.userId == request.auth.uid &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead']);
      allow write: if isAdmin();
    }

    match /notification_logs/{logId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /system_settings/{settingId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}