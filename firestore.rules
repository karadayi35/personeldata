rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == "aalikirmizigul89@gmail.com" ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Checks if the user is the employee associated with the document
    // Assumes the document has an 'employeeId' field which is the Firestore document ID of the employee
    // OR 'authUid' field which is the Firebase Auth UID
    function isEmployeeOwner(data) {
      return isAuthenticated() && (
        (data.authUid == request.auth.uid) || 
        (data.employeeId == request.auth.uid) ||
        (exists(/databases/$(database)/documents/employees/$(data.employeeId)) && 
         get(/databases/$(database)/documents/employees/$(data.employeeId)).data.authUid == request.auth.uid)
      );
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // Users Collection (For Role Management)
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isAdmin() || isOwner(userId); // Users can update their own profile (like role if they are the first admin)
    }

    // Employees Collection
    match /employees/{employeeId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.authUid == request.auth.uid);
      allow create: if isAdmin();
      allow update: if isAdmin() || (isAuthenticated() && resource.data.authUid == request.auth.uid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['avatar', 'updatedAt', 'tempPassword', 'fcmToken', 'notificationsEnabled']));
      allow delete: if isAdmin();
    }

    // Attendance Records
    match /attendance_records/{recordId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.employeeId == get(/databases/$(database)/documents/employees/$(resource.data.employeeId)).id && get(/databases/$(database)/documents/employees/$(resource.data.employeeId)).data.authUid == request.auth.uid);
      // Simplified for now: if the record's employeeId matches a document in employees that has the user's authUid
      allow read: if isAdmin() || (isAuthenticated() && exists(/databases/$(database)/documents/employees/$(resource.data.employeeId)) && get(/databases/$(database)/documents/employees/$(resource.data.employeeId)).data.authUid == request.auth.uid);
      allow create: if isAuthenticated(); // Validation should happen in app logic or more complex rules
      allow update: if isAdmin() || (isAuthenticated() && exists(/databases/$(database)/documents/employees/$(resource.data.employeeId)) && get(/databases/$(database)/documents/employees/$(resource.data.employeeId)).data.authUid == request.auth.uid);
      allow delete: if isAdmin();
    }

    // Branches
    match /branches/{branchId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Shifts
    match /shifts/{shiftId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Employee Shift Assignments
    match /employee_shift_assignments/{assignmentId} {
      // Allow read if user is admin OR the assignment's employeeId matches a document owned by the user
      allow read: if isAdmin() || (
        isAuthenticated() && 
        resource.data.employeeId != null && 
        exists(/databases/$(database)/documents/employees/$(resource.data.employeeId)) && 
        get(/databases/$(database)/documents/employees/$(resource.data.employeeId)).data.authUid == request.auth.uid
      );
      allow write: if isAdmin();
    }

    // Shift Overrides
    match /shift_overrides/{overrideId} {
      allow read: if isAdmin() || (
        isAuthenticated() && 
        resource.data.employeeId != null && 
        exists(/databases/$(database)/documents/employees/$(resource.data.employeeId)) && 
        get(/databases/$(database)/documents/employees/$(resource.data.employeeId)).data.authUid == request.auth.uid
      );
      allow write: if isAdmin();
    }

    // Work Schedules (If exists)
    match /work_schedules/{scheduleId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Holidays
    match /holidays/{holidayId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Announcements
    match /announcements/{announcementId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Leave Requests / Records
    match /leave_requests/{requestId} {
      allow read: if isAdmin() || (isAuthenticated() && exists(/databases/$(database)/documents/employees/$(resource.data.employeeId)) && get(/databases/$(database)/documents/employees/$(resource.data.employeeId)).data.authUid == request.auth.uid);
      allow create: if isAuthenticated();
      allow update: if isAdmin() || (isAuthenticated() && exists(/databases/$(database)/documents/employees/$(resource.data.employeeId)) && get(/databases/$(database)/documents/employees/$(resource.data.employeeId)).data.authUid == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /leave_records/{recordId} {
      allow read: if isAdmin() || (isAuthenticated() && exists(/databases/$(database)/documents/employees/$(resource.data.employeeId)) && get(/databases/$(database)/documents/employees/$(resource.data.employeeId)).data.authUid == request.auth.uid);
      allow write: if isAdmin();
    }

    // Break Records
    match /break_records/{recordId} {
      allow read: if isAdmin() || (isAuthenticated() && exists(/databases/$(database)/documents/employees/$(resource.data.employeeId)) && get(/databases/$(database)/documents/employees/$(resource.data.employeeId)).data.authUid == request.auth.uid);
      allow create: if isAuthenticated();
      allow update: if isAdmin() || (isAuthenticated() && exists(/databases/$(database)/documents/employees/$(resource.data.employeeId)) && get(/databases/$(database)/documents/employees/$(resource.data.employeeId)).data.authUid == request.auth.uid);
      allow delete: if isAdmin();
    }

    // Other collections (Admin only or restricted)
    match /leave_balances/{balanceId} {
      allow read: if isAdmin() || (isAuthenticated() && exists(/databases/$(database)/documents/employees/$(resource.data.employeeId)) && get(/databases/$(database)/documents/employees/$(resource.data.employeeId)).data.authUid == request.auth.uid);
      allow write: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /email_logs/{logId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
    
    match /salary_configs/{configId} {
      allow read, write: if isAdmin();
    }
    
    match /salary_records/{recordId} {
      allow read: if isAdmin() || (isAuthenticated() && exists(/databases/$(database)/documents/employees/$(resource.data.employeeId)) && get(/databases/$(database)/documents/employees/$(resource.data.employeeId)).data.authUid == request.auth.uid);
      allow write: if isAdmin();
    }

    // Notifications
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead']);
      allow write: if isAdmin();
    }

    // Notification Logs
    match /notification_logs/{logId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // System Settings
    match /system_settings/{settingId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
